# Copy to deploy.local.env (which is gitignored) and fill in the real values.
# deploy.sh sources this file so the SSH password never sits on disk inside
# the repo or appears on a process command line.
REMOTE_HOST=10.0.0.0
REMOTE_USER=changeme
SSHPASS=changeme

# Optional overrides
# MUW_SUBDOMAIN=muw.example.net
# MUW_CLIENT_URL=https://muw.example.net  # set when frontend is on a different host
# MUW_PORT=5003
